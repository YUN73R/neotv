{
    "cli": {
        "version": ">= 19.1.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "channel": "development",
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            }
        },
        "preview": {
            "channel": "preview",
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "channel": "production",
            "autoIncrement": true,
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease",
                "image": "latest",
                "resourceClass": "large",
                "ndk": "25.1.8937393"
            },
            "env": {
                "EXPO_TV": "1",
                "EXPO_USE_BARE_WORKFLOW": "1"
            },
            "developmentClient": false
        }
    },
    "submit": {
        "production": {}
    }
}