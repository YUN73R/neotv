{
    "expo": {
        "icon": "./src/assets/images/logo.png",
        "name": "极简TV",
        "description": "a free movie of tv app",
        "slug": "aifreetvapp",
        "version": "1.0.0",
        "orientation": "landscape",
        "updates": {
            "url": "https://u.expo.dev/34994044-990b-446d-9d35-8dfb80da31b4",
            "checkAutomatically": "ON_LOAD"
        },
        "android": {
            "package": "com.aifreetv.app",
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/images/logo.png",
                "backgroundColor": "#8B5CF6"
            },
            "usesCleartextTraffic": true,
            "runtimeVersion": "1.0.0",
            "permissions": [
                "INTERNET",
                "ACCESS_NETWORK_STATE",
                "WAKE_LOCK",
                "ACCESS_WIFI_STATE"
            ]
        },
        "splash": {
            "image": "./src/assets/images/start.png",
            "resizeMode": "cover",
            "backgroundColor": "#8B5CF6",
            "imageWidth": 400
        },
        "plugins": [
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#8B5CF6",
                    "image": "./src/assets/images/start.png",
                    "imageWidth": 400
                }
            ],
            "expo-status-bar",
            "expo-video",
            "@react-native-tvos/config-tv"
        ],
        "extra": {
            "eas": {
                "projectId": "34994044-990b-446d-9d35-8dfb80da31b4"
            }
        },
        "ios": {
            "runtimeVersion": {
                "policy": "appVersion"
            }
        }
    }
}