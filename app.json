{
    "expo": {
        "icon": "./src/assets/images/logo-contain.png",
        "name": "极简TV",
        "description": "a free movie of tv app",
        "slug": "aifreetvapp",
        "owner": "yun73r",
        "version": "1.0.0",
        "orientation": "landscape",
        "githubUrl": "https://github.com/YUN73R/neotv",
        "backgroundColor": "#8B5CF6",
        "updates": {
            "url": "https://u.expo.dev/34994044-990b-446d-9d35-8dfb80da31b4",
            "checkAutomatically": "ON_LOAD",
            "fallbackToCacheTimeout": 60000
        },
        "android": {
            "package": "com.aifreetv.app",
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/images/logo-contain.png",
                "backgroundImage": "./src/assets/images/start.png",
                "backgroundColor": "#8B5CF6"
            },
            "usesCleartextTraffic": true,
            "runtimeVersion": "1.0.0",
            "permissions": [
                "INTERNET",
                "ACCESS_NETWORK_STATE",
                "WAKE_LOCK",
                "ACCESS_WIFI_STATE"
            ]
        },
        "plugins": [
            "expo-status-bar",
            "expo-video",
            "@react-native-tvos/config-tv"
        ],
        "extra": {
            "eas": {
                "projectId": "34994044-990b-446d-9d35-8dfb80da31b4"
            }
        },
        "ios": {
            "runtimeVersion": {
                "policy": "appVersion"
            }
        }
    }
}